{
  "name": "@forsakringskassan/commitlint-config",
  "version": "4.2.1",
  "description": "FK commitlint shareable config",
  "keywords": [
    "commitlint"
  ],
  "homepage": "https://github.com/Forsakringskassan/commitlint-config",
  "bugs": "https://github.com/Forsakringskassan/commitlint-config/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Forsakringskassan/commitlint-config.git"
  },
  "license": "MIT",
  "author": "Försäkringskassan",
  "type": "module",
  "exports": {
    ".": "./dist/config/default.js",
    "./default": "./dist/config/default.js",
    "./no-jira": "./dist/config/no-jira.js",
    "./lint-staged": "./lint-staged.js"
  },
  "main": "dist/config/default.js",
  "bin": {
    "commitlint": "bin/commitlint.js",
    "commitlint-config": "bin/install.js",
    "lint-staged": "bin/lint-staged.js"
  },
  "files": [
    "bin",
    "dist",
    "gitmessage",
    "lint-staged.js",
    "hooks.js"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc && node build.js ",
    "postbuild": "cp -R node_modules/@commitlint/config-validator/lib/commitlint.schema.json dist/",
    "eslint": "eslint .",
    "eslint:fix": "eslint --fix .",
    "prepack": "run-s pkg:mangle",
    "postpack": "run-s pkg:restore",
    "pkg:mangle": "release-prepack package.json --bundle --retain-scripts",
    "pkg:restore": "release-postpack package.json",
    "prepare": "simple-git-hooks src/hooks.ts && git config commit.template gitmessage",
    "prepublishOnly": "run-s pkg:mangle",
    "prettier:check": "prettier . --check",
    "prettier:write": "prettier . --write",
    "pretest": "run-s eslint prettier:check",
    "test": "vitest run && vitest run --mode integration",
    "test:integration": "vitest --mode integration",
    "test:unit": "vitest run"
  },
  "commitlint": {
    "extends": [
      "./dist/config/no-jira"
    ]
  },
  "prettier": "@forsakringskassan/prettier-config",
  "release": {
    "extends": "@forsakringskassan/semantic-release-config"
  },
  "dependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "conventional-commits-filter": "6.0.1",
    "conventional-commits-parser": "7.1.0",
    "glob": "^13.0.0",
    "is-ci": "^4.0.0",
    "lint-staged": "17.0.8",
    "nano-spawn": "2.1.0"
  },
  "devDependencies": {
    "@commitlint/format": "21.2.0",
    "@commitlint/lint": "21.2.0",
    "@commitlint/load": "21.2.0",
    "@forsakringskassan/eslint-config": "15.3.13",
    "@forsakringskassan/eslint-config-cli": "15.3.0",
    "@forsakringskassan/eslint-config-typescript": "15.3.8",
    "@forsakringskassan/eslint-config-typescript-typeinfo": "15.3.8",
    "@forsakringskassan/eslint-config-vitest": "15.3.7",
    "@forsakringskassan/prettier-config": "3.7.7",
    "@html-validate/release-scripts": "7.3.6",
    "@tsconfig/node22": "22.0.5",
    "@tsconfig/strictest": "2.0.8",
    "@types/is-ci": "3.0.4",
    "@types/node": "22.20.1",
    "@typescript/native": "npm:typescript@7.0.2",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "esbuild": "0.28.1",
    "memfs": "4.64.0",
    "npm-pkg-lint": "5.1.11",
    "npm-run-all2": "9.0.2",
    "rimraf": "6.1.3",
    "simple-git-hooks": "2.13.1",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">= 22.22.1",
    "npm": ">= 10.0.0"
  },
  "allowScripts": {
    "esbuild": true,
    "fsevents": false,
    "simple-git-hooks": true,
    "unrs-resolver": true
  },
  "externalDependencies": [
    "lint-staged"
  ]
}
